# Database
DATABASE_URL=sqlite+aiosqlite:///./irrigation.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
API_KEY=your-secure-api-key-here

# Anomaly Detection Thresholds
MOISTURE_SPIKE_THRESHOLD=20       # sudden drop > 20% in one reading = anomaly
MOISTURE_SATURATION_HOURS=6       # hours of 90%+ moisture = overwater risk
TEMP_STRESS_HIGH=38               # celsius
TEMP_STRESS_LOW=5                 # celsius

# Prediction Model
LOOKBACK_READINGS=24              # number of past readings used for regression
MIN_READINGS_FOR_PREDICTION=5     # minimum readings required before ML kicks in
